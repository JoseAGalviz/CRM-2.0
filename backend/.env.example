PORT=3000
DB_PATH=./crm.db

# Genera secretos con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Orígenes permitidos por CORS (separados por coma)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# URL del frontend (para links en emails)
FRONTEND_URL=http://localhost:5173

# SMTP para envío de emails (dejar vacío para usar console.log en dev)
# Proveedores: Gmail, Resend (smtp.resend.com:465), Brevo, Mailgun, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="CRM Pro <noreply@tudominio.com>"
